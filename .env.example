ANALYSIS_BACKEND=redroid_remote
REDIS_BROKER_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Redroid Remote Backend (scheme two)
REDROID_SSH_HOST=61.152.73.88
REDROID_SSH_PORT=22
REDROID_SSH_USER=
REDROID_SSH_KEY_PATH=
REDROID_SSH_PASSWORD=
REDROID_SLOTS_JSON=[{"name":"redroid-1","adb_serial":"61.152.73.88:16555","container_name":"redroid-1"},{"name":"redroid-2","adb_serial":"61.152.73.88:16556","container_name":"redroid-2"},{"name":"redroid-3","adb_serial":"61.152.73.88:16557","container_name":"redroid-3"}]
